# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/nodalpulse

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=nodalpulse-docs

# Sentry
SENTRY_DSN=

# App
LOG_LEVEL=INFO
ENVIRONMENT=development

# Brief personalization
# Days to look back when a user has no prior brief (first-ever brief window).
# Subsequent briefs window from the last sent brief date, so this only affects
# the first brief. Set higher in Railway if you want new users to see a full week.
MAX_LOOKBACK_DAYS=7

# Worker spend circuit breaker: if the past hour's LLM cost exceeds this, the
# worker pauses for 1 hour before processing more jobs. Default $5.00/hr.
WORKER_SPEND_CIRCUIT_USD_PER_HOUR=5.0
